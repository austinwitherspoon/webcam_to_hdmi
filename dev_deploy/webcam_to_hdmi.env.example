# Copy this file to /etc/default/webcam_to_hdmi on the Raspberry Pi.
# Note: deploy/setup_pi.sh auto-generates this file from detected hardware.
# Confirm values with:
#   ls -l /dev/v4l/by-path
#   modetest -M vc4

USB1_CAM_DEV=/dev/v4l/by-path/usb-1-1-video-index0
USB2_CAM_DEV=/dev/v4l/by-path/usb-1-2-video-index0

# Example connector IDs only. Use modetest to confirm actual IDs.
HDMI1_CONNECTOR_ID=32
HDMI2_CONNECTOR_ID=41

# DRM card used by kmssink.
DRM_CARD_DEV=/dev/dri/card1

WIDTH=1920
HEIGHT=1080
FPS=30
POLL_MS=1000
